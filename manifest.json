{
  "manifest_version": 3,
  "name": "Reader's Block",
  "version": "2.2",
  "description": "Full text in the popup or on the page",
  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://www.gutenberg.org/*",
    "https://gutenberg.org/*",
    "https://aleph.gutenberg.org/*",
    "https://cache.gutenberg.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "eBooks"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "commands": {
    "open-popup": {
      "suggested_key": { "default": "Alt+Shift+G" },
      "description": "Open Reader"
    }
  }
}
